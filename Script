from mcp3208 import MCP3208
from time import sleep
import datetime
import os
import csv

filename = "data_log.csv"
# Create header row in new CSV file
csv = open(filename, 'w')
csv.write("Timestamp,CH0,CH1,CH2,CH3,CH4,CH5,CH6,CH7\n")
csv.close

mcp = MCP3208()

# Main program loop.
while True:
    # Read all the ADC channel values in a list.
    values = [0] * 8
    for i in range(8):
        # The mcp.read function will get the value of the specified channel (0-7).
        values[i] = mcp.read(i)
    # Get timestamp and convert it to a character string to add to printed output.
    stamp = datetime.datetime.now()
    ts = stamp.strftime("%d/%m %H:%M:%S")
    # Write recorded values and timestamp.
    entry = ts + "," + .format(*values) + "\n"

    # Log (append) entry into file
    csv = open(filename, 'a')
    try:
        csv.write(entry)
    finally:
        csv.close()

    # Pause for a tenth of a second.
    sleep(0.1)

# When all the writing has been completed, print the CSV contents
csv = open(filename, 'r')
print(csv.read())
csv.close()