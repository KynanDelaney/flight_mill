from mcp3208 import MCP3208
from time import sleep
import datetime
import csv

mcp = MCP3208()

today = str(datetime.date.today().strftime("%d-%m"))

# Create/Open csv. Write headers and close.
with open(today + "datalog.csv", "a") as log:
    log.write("Time, CH0,CH1,CH2,CH3,CH4,CH5,CH6,CH7\n")
log.close

# Main program loop.
while True:
    results = ""

    # Read all the ADC channel values in a list.
    values = [0] * 8
    for i in range(8):
        # The mcp.read function will get the value of the specified channel (0-7).
        values[i] = mcp.read(i)

        # Object string that can be passed to later log/csv lines.
        results = results + str(values[i]) + ","

    # Get timestamp and convert it to a character string to add to output
    stamp = datetime.datetime.now()
    ts = stamp.strftime("%d/%m %H:%M:%S")

    # Gathering time and channel logs for printing to csv
    logged = ts + "," +  results + "\n"

    # Pause for a tenth of a second.
    sleep(0.1)

    # Re-open csv and write logs for duration of run-time. Script arrested by "CTRL + C".
    with open("datalog.csv", "a") as log:
        log.write(logged)